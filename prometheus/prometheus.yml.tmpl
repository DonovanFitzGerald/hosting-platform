global:
    scrape_interval: 15s
    evaluation_interval: 15s

scrape_configs:
    - job_name: prometheus
      static_configs:
          - targets:
                - prometheus:9090

    - job_name: node-exporter
      static_configs:
          - targets:
                - node-exporter:9100

    - job_name: cadvisor
      static_configs:
          - targets:
                - cadvisor:8080

    - job_name: redis-exporter
      static_configs:
          - targets:
                - redis-exporter:9121

    - job_name: traefik
      static_configs:
          - targets:
                - traefik:8080

    - job_name: blackbox-http
      metrics_path: /probe
      params:
          module: [http_2xx]
      file_sd_configs:
          - files:
                - /etc/prometheus/blackbox-targets-static.yml
      relabel_configs:
          - source_labels: [__address__]
            target_label: __param_target
          - source_labels: [__param_target]
            target_label: instance
          - target_label: __address__
            replacement: blackbox-exporter:9115

    - job_name: blackbox-http-docker-labels
      metrics_path: /probe
      params:
          module: [http_2xx]
      docker_sd_configs:
          - host: unix:///var/run/docker.sock
            refresh_interval: 30s
            filters:
                - name: network
                  values:
                      - proxy
      relabel_configs:
          - source_labels:
                [__meta_docker_container_label_monitoring_blackbox_enable]
            regex: true
            action: keep
          - source_labels: [__meta_docker_container_name]
            regex: /(.+)
            target_label: container
          - source_labels:
                [__meta_docker_container_label_com_docker_compose_service]
            regex: (.+)
            target_label: service
            replacement: $1
          - source_labels: [__meta_docker_network_name]
            target_label: network
          - target_label: __tmp_blackbox_scheme
            replacement: https
          - source_labels:
                [__meta_docker_container_label_monitoring_blackbox_scheme]
            regex: (https?)
            target_label: __tmp_blackbox_scheme
            replacement: $1
          - target_label: __tmp_blackbox_path
            replacement: /
          - source_labels:
                [__meta_docker_container_label_monitoring_blackbox_path]
            regex: (/.+)
            target_label: __tmp_blackbox_path
            replacement: $1
          - source_labels:
                [
                    __meta_docker_container_label_monitoring_blackbox_hostname,
                    __tmp_blackbox_scheme,
                    __tmp_blackbox_path,
                ]
            separator: ;
            regex: ([^;]+);(https?);(.+)
            target_label: __param_target
            replacement: $2://$1$3
          - source_labels:
                [__meta_docker_container_label_monitoring_blackbox_target]
            regex: (https?://.+)
            target_label: __param_target
            replacement: $1
          - source_labels:
                [__meta_docker_container_label_monitoring_blackbox_module]
            regex: (.+)
            target_label: __param_module
            replacement: $1
          - source_labels: [__param_target]
            regex: .+
            action: keep
          - source_labels: [__param_target]
            target_label: instance
          - target_label: __address__
            replacement: blackbox-exporter:9115

    - job_name: do-managed-mysql
      scheme: https
      metrics_path: /metrics
      tls_config:
          ca_file: /etc/prometheus/certs/do-managed-mysql-ca.crt
      basic_auth:
          username: ${DO_MANAGED_MYSQL_METRICS_USERNAME}
          password: ${DO_MANAGED_MYSQL_METRICS_PASSWORD}
      dns_sd_configs:
          - names:
                - ${DO_MANAGED_MYSQL_METRICS_HOST}
            type: A
            port: 9273
            refresh_interval: 15s
